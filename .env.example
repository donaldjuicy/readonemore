# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/readonemore

# ── Auth ────────────────────────────────────────────
JWT_SECRET=replace-this-with-a-long-random-string

# ── Shipping rules ──────────────────────────────────
SHIPPING_FEE_DKK=49
FREE_SHIPPING_MIN_BOOKS=3

# ── PDF output ──────────────────────────────────────
PDF_OUTPUT_DIR=./reports

# ── MobilePay (test/sandbox values for now) ─────────
MOBILEPAY_ACCESS_TOKEN=
MOBILEPAY_MERCHANT_SERIAL_NUMBER=
MOBILEPAY_SUBSCRIPTION_KEY=
MOBILEPAY_REDIRECT_URL=http://localhost:3000/order-confirmation

# ── External APIs ───────────────────────────────────
GOOGLE_BOOKS_API_KEY=